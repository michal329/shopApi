<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="c:\temp\internal-nlog-AspNetCore.txt">

	<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
		<add assembly="NLog.MailKit"/>
	</extensions>

	<targets>
		<target xsi:type="File" name="mylogfile" fileName="c:\temp\logger-${shortdate}.json">
			<layout xsi:type="JsonLayout">
				<attribute name="timestamp" layout="${longdate}" />
				<attribute name="level" layout="${level}" />
				<attribute name="message" layout="${message}" />
				<attribute name="logger" layout="${logger}" />
				<attribute name="exception" layout="${exception:format=tostring}" />
			</layout>
		</target>

		<!-- email target kept but disabled in rules below -->
		<target name="email" xsi:type="Mail"
		  subject="Sent From The Logger!"
		  to="sprung5866769@gmail.com"
		  from="siteloggermail@gmail.com"
		  body="${message}${newline}"
		  smtpUserName="siteloggermail@gmail.com"
		  secureSocketOption="SslOnConnect"
		  skipCertificateValidation="true"
		  smtpAuthentication="Basic"
		  enableSsl="true"
		  smtpPassword="xclbrhazlcfxuwps"
		  smtpServer="smtp.gmail.com"
		  smtpPort="465"
		  timeout="5000"
    />
	</targets>

	<rules>
		<logger name="Microsoft.*" maxlevel="Info" final="true" />
		<logger name="System.Net.Http.*" maxlevel="Info" final="true" />
		<logger name="*" minlevel="Info" writeTo="mylogfile" />
		<!-- email rule commented out until DB issue is fixed, to avoid long hangs -->
		<!-- <logger name="*" minlevel="Error" writeTo="email" /> -->
	</rules>
</nlog>